<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Facebook Audience Network App ID.
        Replace "0" with your real Facebook App ID from
        https://developers.facebook.com/apps/ before going to production.
        Only required because the Facebook mediation adapter
        (com.google.ads.mediation:facebook) declares this meta-data in its
        AndroidManifest, which is merged into the app manifest at build time.
    -->
    <string name="facebook_app_id"></string>
    <string name="facebook_client_token"></string>
</resources>
